+"""MLIS (HPE Machine Learning Inference Server) implementation of transcription service.
+
+Calls an external OpenAI-compatible Whisper API instead of loading the model locally.
+"""
+
+import io
+import wave
+from typing import Any
+
+import httpx
+import numpy as np
+
+from app.core.logging import logger
+
+
+class MLISTranscriptionService:
+    """
+    MLIS-based transcription service that calls an external Whisper API.
+
+    The remote endpoint must be OpenAI-compatible (POST /v1/audio/transcriptions).
+    """
+
+    def __init__(self, api_url: str, api_key: str, timeout: float = 300.0) -> None:
+        self.api_url = api_url.rstrip("/")
+        self.api_key = api_key
+        self.timeout = timeout
+        self.logger = logger
+
+    @staticmethod
+    def _audio_to_wav_bytes(audio: np.ndarray, sample_rate: int = 16000) -> bytes:
+        """Convert float32 numpy audio array to WAV bytes."""
+        buf = io.BytesIO()
+        pcm = (audio * 32767).astype(np.int16)
+        with wave.open(buf, "wb") as wf:
+            wf.setnchannels(1)
+            wf.setsampwidth(2)
+            wf.setframerate(sample_rate)
+            wf.writeframes(pcm.tobytes())
+        return buf.getvalue()
+
+    def transcribe(
+        self,
+        audio: np.ndarray[Any, np.dtype[np.float32]],
+        task: str,
+        asr_options: dict[str, Any],
+        vad_options: dict[str, Any],
+        language: str,
+        batch_size: int,
+        chunk_size: int,
+        model: str,
+        device: str,
+        device_index: int,
+        compute_type: str,
+        threads: int,
+    ) -> dict[str, Any]:
+        """Transcribe audio by calling the remote MLIS Whisper endpoint."""
+        self.logger.info(
+            "Sending audio to MLIS Whisper API at %s (model=%s, language=%s, task=%s)",
+            self.api_url,
+            model,
+            language,
+            task,
+        )
+
+        wav_bytes = self._audio_to_wav_bytes(audio)
+        endpoint = f"{self.api_url}/v1/audio/transcriptions"
+
+        data: dict[str, str] = {
+            "model": model,
+            "language": language,
+            "response_format": "verbose_json",
+            "timestamp_granularities[]": "segment",
+        }
+        if task == "translate":
+            endpoint = f"{self.api_url}/v1/audio/translations"
+            data.pop("language", None)
+
+        with httpx.Client(timeout=self.timeout) as client:
+            response = client.post(
+                endpoint,
+                headers={"Authorization": f"Bearer {self.api_key}"},
+                data=data,
+                files={"file": ("audio.wav", wav_bytes, "audio/wav")},
+            )
+            response.raise_for_status()
+
+        result = response.json()
+        self.logger.info("MLIS Whisper API returned %d segments", len(result.get("segments", [])))
+
+        # Map OpenAI verbose_json response to WhisperX-compatible format
+        segments = []
+        for seg in result.get("segments", []):
+            segments.append({
+                "start": seg.get("start", 0.0),
+                "end": seg.get("end", 0.0),
+                "text": seg.get("text", ""),
+            })
+
+        return {
+            "segments": segments,
+            "language": result.get("language", language),
+        }
+
+    def load_model(self, *args: Any, **kwargs: Any) -> None:
+        """No-op: model is served remotely."""
+
+    def unload_model(self) -> None:
+        """No-op: model is served remotely."""
