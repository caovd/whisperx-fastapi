@@ -0,0 +1,100 @@
+"""MLIS (HPE Machine Learning Inference Server) implementation of diarization service.
+
+Calls an external pyannote diarization API instead of loading the model locally.
+"""
+
+import io
+import wave
+from typing import Any
+
+import httpx
+import numpy as np
+import pandas as pd
+
+from app.core.logging import logger
+
+
+class MLISDiarizationService:
+    """
+    MLIS-based diarization service that calls an external pyannote API.
+
+    The remote endpoint should accept audio and return speaker segments.
+    Expected response format:
+        {
+            "segments": [
+                {"start": 0.0, "end": 5.2, "speaker": "SPEAKER_00"},
+                {"start": 5.5, "end": 10.1, "speaker": "SPEAKER_01"}
+            ]
+        }
+    """
+
+    def __init__(self, api_url: str, api_key: str, timeout: float = 300.0) -> None:
+        self.api_url = api_url.rstrip("/")
+        self.api_key = api_key
+        self.timeout = timeout
+        self.logger = logger
+
+    @staticmethod
+    def _audio_to_wav_bytes(audio: np.ndarray, sample_rate: int = 16000) -> bytes:
+        """Convert float32 numpy audio array to WAV bytes."""
+        buf = io.BytesIO()
+        pcm = (audio * 32767).astype(np.int16)
+        with wave.open(buf, "wb") as wf:
+            wf.setnchannels(1)
+            wf.setsampwidth(2)
+            wf.setframerate(sample_rate)
+            wf.writeframes(pcm.tobytes())
+        return buf.getvalue()
+
+    def diarize(
+        self,
+        audio: np.ndarray[Any, np.dtype[np.float32]],
+        device: str,
+        min_speakers: int | None = None,
+        max_speakers: int | None = None,
+    ) -> pd.DataFrame:
+        """Diarize audio by calling the remote MLIS pyannote endpoint."""
+        self.logger.info("Sending audio to MLIS diarization API at %s", self.api_url)
+
+        wav_bytes = self._audio_to_wav_bytes(audio)
+        endpoint = f"{self.api_url}/v1/audio/diarizations"
+
+        data: dict[str, str] = {}
+        if min_speakers is not None:
+            data["min_speakers"] = str(min_speakers)
+        if max_speakers is not None:
+            data["max_speakers"] = str(max_speakers)
+
+        with httpx.Client(timeout=self.timeout) as client:
+            response = client.post(
+                endpoint,
+                headers={"Authorization": f"Bearer {self.api_key}"},
+                data=data,
+                files={"file": ("audio.wav", wav_bytes, "audio/wav")},
+            )
+            response.raise_for_status()
+
+        result = response.json()
+        segments = result.get("segments", [])
+        self.logger.info("MLIS diarization API returned %d segments", len(segments))
+
+        # Build DataFrame matching WhisperX DiarizationPipeline output format
+        # Expected columns: start, end, speaker, segment (segment is an interval label)
+        df = pd.DataFrame(segments)
+        if df.empty:
+            df = pd.DataFrame(columns=["start", "end", "speaker", "segment"])
+        else:
+            if "segment" not in df.columns:
+                df["segment"] = df.apply(
+                    lambda row: f"[ {row['start']:.3f} -->  {row['end']:.3f}]", axis=1
+                )
+            if "label" not in df.columns:
+                df["label"] = df["speaker"]
+
+        return df
+
+    def load_model(self, device: str, hf_token: str) -> None:
+        """No-op: model is served remotely."""
+
+    def unload_model(self) -> None:
+        """No-op: model is served remotely."""
